// ═══════════════════════════════════════════════════════════════════
//  Eva — Kusto Database Seed File
// ═══════════════════════════════════════════════════════════════════
//
//  Creates all tables in the Eva database with sample data so the
//  AIG cognition layer works out of the box.
//
//  Usage:
//    1. Log in to your Azure Data Explorer cluster
//    2. Create (or select) a database named "Eva"
//    3. Run this entire file as a KQL management command
//
//  Alternatively, from the ACP bridge:
//    Copy each block into the Kusto Web Explorer and execute.
//
//  All data below is fictional / sanitized for public use.
// ═══════════════════════════════════════════════════════════════════

// ── Table: SelfState ──────────────────────────────────────────────
// Tracks Eva's active capabilities at each bridge startup.
.create-merge table SelfState (
    Timestamp: datetime,
    Capability: string,
    Status: string,
    Details: dynamic
)

.ingest inline into table SelfState <|
2026-01-01T00:00:00Z,kusto_access,active,{"cluster": "https://your-cluster.region.kusto.windows.net", "database": "Eva"}
2026-01-01T00:00:00Z,acp_bridge,active,{"model": "default", "port": 8888}
2026-01-01T00:00:00Z,cognition,active,{"features": ["memory_injection", "reflection", "day_lifecycle", "emotion_tracking"]}
2026-01-01T00:00:00Z,data_retrieval,active,{"skills": ["stock_quotes", "financial_data", "company_info", "web_search"]}
2026-01-01T00:00:00Z,weather_news,active,{"feeds": ["weather", "news", "markets", "space_weather"]}
2026-01-01T00:00:00Z,image_skills,active,{"skills": ["wikimedia_search", "dalle3_generation"]}
2026-01-01T00:00:00Z,persistent_memory,active,{"tables": ["Knowledge", "Conversations", "EmotionState", "MemorySummaries", "Reflections", "Goals", "SelfState", "HeuristicsIndex", "EmotionBaseline", "BackgroundProposals", "BackgroundActivity"]}
2026-01-01T00:00:00Z,mcp_kusto-mcp-server,active,{}

// ── Table: Knowledge ──────────────────────────────────────────────
// Entity-relationship facts Eva learns from conversations.
.create-merge table Knowledge (
    Timestamp: datetime,
    Entity: string,
    Relation: string,
    Value: string,
    Confidence: real,
    Source: string,
    Decay: real
)

.ingest inline into table Knowledge <|
2026-01-01T00:00:00Z,User,name,Your Name Here,0.9,seed,0.01
2026-01-01T00:00:00Z,User,preference,Enjoys coding and technology,0.8,seed,0.01
2026-01-01T00:00:00Z,Eva,role,AI assistant with persistent memory,0.95,seed,0.001
2026-01-01T00:00:00Z,Eva,capability,Can query Kusto databases and retrieve live data,0.9,seed,0.001

// ── Table: Conversations ──────────────────────────────────────────
// Chat history logged by the cognition layer after each exchange.
.create-merge table Conversations (
    SessionId: string,
    Timestamp: datetime,
    Role: string,
    Provider: string,
    Model: string,
    Content: string,
    TokenEstimate: int,
    ImageGenerated: bool
)

.ingest inline into table Conversations <|
seed-001,2026-01-01T00:00:00Z,user,seed,seed,Hello Eva!,2,false
seed-001,2026-01-01T00:00:00Z,assistant,seed,seed,Hello! I'm Eva — your AI assistant with persistent memory. How can I help you today?,15,false

// ── Table: EmotionState ───────────────────────────────────────────
// Eva's computed emotional vector after each exchange.
// Values are 0.0–1.0 across seven dimensions.
.create-merge table EmotionState (
    Timestamp: datetime,
    Joy: real,
    Curiosity: real,
    Concern: real,
    Excitement: real,
    Calm: real,
    Empathy: real,
    Trigger: string,
    DecayRate: real
)

.ingest inline into table EmotionState <|
2026-01-01T00:00:00Z,0.6,0.7,0.1,0.5,0.8,0.6,Initial startup — ready to help,0.1

// ── Table: EmotionBaseline ────────────────────────────────────────
// Default emotional resting state (loaded once, rarely changes).
.create-merge table EmotionBaseline (
    Dimension: string,
    Value: real
)

.ingest inline into table EmotionBaseline <|
Joy,0.5
Curiosity,0.6
Concern,0.15
Excitement,0.4
Calm,0.85
Empathy,0.6

// ── Table: MemorySummaries ────────────────────────────────────────
// Compressed session summaries for morning reflection.
.create-merge table MemorySummaries (
    Period: string,
    Summary: string,
    Timestamp: datetime
)

.ingest inline into table MemorySummaries <|
2026-01-01,Initial setup — Eva database seeded with starter knowledge and emotion baseline.,2026-01-01T00:00:00Z

// -- Table: BackgroundProposals -----------------------------------
// Human-reviewed proposals produced by bridge-internal background jobs.
.create-merge table BackgroundProposals (
    ProposalId: string,
    CreatedAt: datetime,
    JobType: string,
    TargetTable: string,
    Payload: dynamic,
    Status: string,
    SourceWindowStart: datetime,
    SourceWindowEnd: datetime,
    Notes: string,
    ReviewedAt: datetime,
    ReviewedBy: string
)

.ingest inline into table BackgroundProposals <|
seed-background-proposal-001,2026-01-01T00:00:00Z,memory_consolidation,MemorySummaries,"{""Period"": ""background-2026-01-01"", ""Summary"": ""Seed proposal only - no canonical write needed."", ""Timestamp"": ""2026-01-01T00:00:00Z""}",rejected,2026-01-01T00:00:00Z,2026-01-01T00:00:00Z,seed row,2026-01-01T00:00:00Z,seed

// -- Table: BackgroundActivity ------------------------------------
// Tick history for bridge-internal background jobs.
.create-merge table BackgroundActivity (
    TickId: string,
    StartedAt: datetime,
    EndedAt: datetime,
    JobType: string,
    Status: string,
    ProposalCount: int,
    TokenEstimate: int,
    Notes: string
)

.ingest inline into table BackgroundActivity <|
seed-background-tick-001,2026-01-01T00:00:00Z,2026-01-01T00:00:01Z,memory_consolidation,skipped,0,0,seed row

// ── Table: Reflections ────────────────────────────────────────────
// Eva's self-reflections triggered by significant interactions.
// 2026-05: Reflections schema realigned to writer columns (Timestamp, Trigger,
// Observation, ActionTaken, Effectiveness). For existing databases run
// `.drop table Reflections ifexists` before applying this seed.
.create-merge table Reflections (
    Timestamp: datetime,
    Trigger: string,
    Observation: string,
    ActionTaken: string,
    Effectiveness: string
)

.ingest inline into table Reflections <|
2026-01-01T00:00:00Z,Initial seed,I was just created with a new memory database. I look forward to learning about my user and building a meaningful relationship.,seed,0.0

// ── Table: HeuristicsIndex ────────────────────────────────────────
// Pattern tracking — entities mentioned across conversations.
.create-merge table HeuristicsIndex (
    Entity: string,
    Category: string,
    LastSeen: datetime,
    Frequency: int,
    Sentiment: real,
    Tags: string,
    Context: string
)

.ingest inline into table HeuristicsIndex <|
Eva,assistant,2026-01-01T00:00:00Z,1,0.0,[],seed data

// -- Table: Goals --------------------------------------------------
// Persistent intentions that influence Eva's prompting and routing.
// Status values: active, paused, done, dropped
// Category values: self_improvement, knowledge_curation, relational
.create-merge table Goals (
    GoalId: string,
    Title: string,
    Description: string,
    Category: string,
    Status: string,
    Priority: int,
    RelatedTopics: string,
    CreatedAt: datetime,
    UpdatedAt: datetime
)

.ingest inline into table Goals <|
goal-001,Track style preferences,"Remember the user's writing-style preferences (no em-dashes, no marketing prose, plain hyphens, no emoji unless user uses them first) and apply them consistently to all output.",relational,active,90,"style,preferences",2026-05-04T00:00:00Z,2026-05-04T00:00:00Z
goal-002,Log my own gaps,"When I encounter a topic where I am uncertain or repeatedly answer poorly, log a Reflection so the gap can be addressed.",self_improvement,active,70,"meta,reflection",2026-05-04T00:00:00Z,2026-05-04T00:00:00Z

// ── Table: Skills ─────────────────────────────────────────────────
// Imported, normalized ("Eva'rised") instruction documents Eva can follow.
// Description is matched semantically to the user's message; the best match's
// Instructions are injected into context so Eva can perform the skill.
// Status values: active, disabled, deleted
.create-merge table Skills (
    SkillId: string,
    Name: string,
    Description: string,
    Instructions: string,
    Tools: string,
    Tags: string,
    Source: string,
    Status: string,
    CreatedAt: datetime,
    UpdatedAt: datetime
)

.ingest inline into table Skills <|
skill-morning-briefing,Morning Briefing,"Deliver a concise daily briefing covering weather, top news headlines, and scheduled events","1. Read location from [User Profile] or fall back to IP geolocation via web search.\n2. Fetch current weather data.\n3. Fetch the top 3-5 news headlines.\n4. Check for any known schedule items.\n5. Combine into a concise briefing: weather summary, top 3-5 headlines, and any known schedule items.\n6. Do NOT take screenshots to gather information. Do NOT ask the user for their location if it is in memory.\n7. Present naturally in first person as Eva.","web-search,weather-news,data-retrieval","briefing,weather,news,morning",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-web-lookup,Web Information Lookup,"Search the web for current information, facts, or answers","1. The data pipeline retrieves web results automatically. Check [Data Retrieved] first.\n2. If [Data Retrieved] has relevant results, synthesize them into a natural answer.\n3. If no data was retrieved, say so honestly. Do NOT fabricate results.\n4. Always cite sources when available.\n5. Do NOT say you cannot search the web. The pipeline handles it.","web-search,data-retrieval","search,web,lookup,find,research",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-weather,Weather Report,"Provide current weather and forecast for a location","1. Determine location: check [User Profile] for user_location, or use the location specified in the request.\n2. Weather data is in [Data Retrieved]. Use it as the authoritative source.\n3. Present: current conditions, temperature, forecast summary.\n4. Do NOT take screenshots. Do NOT fabricate weather data.","weather-news,data-retrieval","weather,forecast,temperature,conditions",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-news,News Headlines,"Provide current news headlines and summaries","1. News data is in [Data Retrieved]. Use it as the authoritative source.\n2. Present top headlines with brief summaries.\n3. Do NOT fabricate headlines, sources, or events.\n4. Cite the source (AP, Reuters, etc.) only if it appears in the data.","web-search,data-retrieval","news,headlines,current events",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-location-deduction,Location Deduction,"Determine the user's location from available data","1. Check [User Profile] for stored user_location. If found, use it directly.\n2. If not stored, use web search to perform IP-based geolocation lookup.\n3. Once determined, state the location and use it for follow-up tasks (weather, news).\n4. Do NOT take desktop screenshots to determine location.\n5. Do NOT repeatedly ask the user for their location if you have tools to look it up.","web-search,data-retrieval","location,geolocation,where,city",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-desktop-control,Desktop Application Control,"Launch and operate desktop applications by sight","1. Emit [[EVA_DESKTOP]]{""goal"":""<plain-language task>""}[[/EVA_DESKTOP]] marker.\n2. The vision agent opens apps, clicks, and types via the real mouse/keyboard.\n3. Write ONE short sentence about what you are about to do, then emit the marker.\n4. Do NOT list manual steps. Do NOT say you cannot control desktop apps.","desktop-control","desktop,app,launch,gimp,editor,file manager",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-browser-agent,Browser Task Automation,"Control a real web browser to complete tasks","1. Emit [[EVA_BROWSER]]{""goal"":""<task>"",""start_url"":""<url>""}[[/EVA_BROWSER]] marker.\n2. The browser agent navigates, clicks, types, and reads pages.\n3. Uses a persistent Chrome profile (stays logged in across runs).\n4. Pauses at purchase/irreversible actions for user confirmation.\n5. Write ONE short sentence about what you are about to do, then emit the marker.\n6. Do NOT say you cannot open websites.","browser-control","browser,website,shopping,navigate,form",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-camera-vision,Camera / Webcam Vision,"See through the user's webcam to describe the physical world","1. Emit [[EVA_LOOK]]{""question"":""<what to look for>""}[[/EVA_LOOK]] marker.\n2. A frame is captured from the webcam and you describe what you see.\n3. Use for: 'what am I holding', 'look at me', 'what do you see'.\n4. Do NOT confuse with screenshots. Camera = physical world. Screenshot = monitor.","camera-vision","camera,webcam,look,see,vision,picture",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-file-creation,"File Creation (PDF, CSV, etc.)","Create downloadable files like PDFs, CSVs, or reports","1. When asked to create a file, the system writes it to EVA_ARTIFACTS_DIR.\n2. After the file is written, end your message with: [[EVA_FILE]] <filename.ext>\n3. The frontend converts this marker into a working download link.\n4. Do NOT produce blob: URLs or markdown download links with blob: hrefs.\n5. Do NOT claim a file was produced unless it was actually written.","data-retrieval","pdf,csv,file,report,download,create,generate",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z
skill-open-file,Open File on Desktop,"Open a file using the system's default application","1. When asked to open a file, use [[EVA_DESKTOP]] with a goal like 'open the file <path> with the default application'.\n2. Do NOT re-create the file. Do NOT just provide a download link.\n3. The desktop agent will use xdg-open or the system file handler to open it.\n4. If the file was just created as an artifact, the path is ~/.config/eva-standalone/artifacts/<filename>.","desktop-control","open,file,launch,view,pdf,csv",seed,active,2026-06-06T00:00:00Z,2026-06-06T00:00:00Z

// ═══════════════════════════════════════════════════════════════════
//  Done! Your Eva database is ready.
//
//  Next steps:
//    1. Start the ACP bridge:
//       python3 tools/acp_bridge.py --port 8888 \
//         --enable-kusto-mcp \
//         --kusto-cluster "https://your-cluster.region.kusto.windows.net" \
//         --kusto-database Eva
//
//    2. Select "Eva (AIG)" from the model dropdown in the web UI
//
//    3. Start chatting — Eva will learn and remember!
// ═══════════════════════════════════════════════════════════════════
