[Unit]
Description=Eva ACP Bridge - Copilot CLI to HTTP bridge
Documentation=https://github.com/appatalks/eva-agent
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.eva
ExecStart=/usr/bin/env python3 %h/.eva/tools/acp_bridge.py --bind 127.0.0.1 --port 8888
Restart=on-failure
RestartSec=10
StandardOutput=null
StandardError=null
SyslogIdentifier=acp-bridge
Environment=HOME=%h
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=default.target
